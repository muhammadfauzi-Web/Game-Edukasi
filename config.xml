<?xml version='1.0' encoding='utf-8'?>
<widget id="com.edukasi.anak" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Edukasi</name>
    <description>
        Aplikasi pembelajaran interaktif untuk anak-anak.
    </description>
    <author email="muhammadfauziarrasyid@email.com" href="https://edukasi.com">
        Muhammad Fauzi
    </author>

    <content src="index.html" />
    
    <engine name="android" spec="13.0.0" />

    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />

    <preference name="DisallowOverscroll" value="true" />
    <preference name="android-minSdkVersion" value="24" />
    <preference name="android-targetSdkVersion" value="34" />
    <preference name="BackupWebStorage" value="none" />
    <preference name="SplashMaintainAspectRatio" value="true" />
    <preference name="FadeSplashScreenDuration" value="300" />
    <preference name="SplashShowOnlyFirstTime" value="false" />
    <preference name="ShowSplashScreenSpinner" value="false" />
    <preference name="AutoHideSplashScreen" value="true" />
    <preference name="Orientation" value="portrait" />
    <preference name="Fullscreen" value="false" />

    <icon src="www/icon-512.png" />
    <icon density="ldpi" src="www/icon-192.png" />
    <icon density="mdpi" src="www/icon-192.png" />
    <icon density="hdpi" src="www/icon-192.png" />
    <icon density="xhdpi" src="www/icon-192.png" />
    <icon density="xxhdpi" src="www/icon-512.png" />
    <icon density="xxxhdpi" src="www/icon-512.png" />

    <platform name="android">
        <allow-intent href="market:*" />
        <preference name="AndroidWindowSplashScreenBackground" value="#4ECDC4" />
        <preference name="AndroidWindowSplashScreenAnimatedIcon" value="www/icon-512.png" />
    </platform>

    <platform name="ios">
        <allow-intent href="itms:*" />
        <allow-intent href="itms-apps:*" />
    </platform>

    <plugin name="cordova-plugin-splashscreen" spec="^6.0.2" />
    <plugin name="cordova-plugin-statusbar" spec="^4.0.0" />
    <plugin name="cordova-plugin-device" spec="^3.0.0" />
</widget>
